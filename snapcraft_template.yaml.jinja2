name: husarion-depthai
adopt-info: husarion-depthai
license: Apache-2.0
summary: OAK-x cameras driver for Husarion robots
icon: snap/gui/icon.png
description: |
  The `husarion-depthai` snap contains all the necessary software to bring the OAK-x cameras up.

  **Tip**

  The default camera parameters do not include depth image computation. To enable depth topic transmission, set the parameter to `i_pipeline_type: RGBD`. Path to params file: `/var/snap/husarion-depthai/current/camera-params-default.yaml`

  **Parameters**

  The snap provides the following configurable parameters (`param name`: `default value`):

  * `driver`: `{...}`
  * `ros`: `{...}`

  The `ros` contains the following keys:

  * `ros.domain-id`: `0` - Sets the `ROS_DOMAIN_ID` environment variable for the ROS driver.
  * `ros.localhost-only`: `0` - Sets the `ROS_LOCALHOST_ONLY` environment variable for the ROS driver.
  * `ros.transport`: `udp` - Configures DDS transport. Options are `udp`, `shm`, `builtin` (or `rmw_fastrtps_cpp`), `rmw_cyclonedds_cpp`. Corresponding DDS XML files can be found in the `/var/snap/husarion-depthai/common` directory (custom FastDDS setups can also be created here).
  * `ros.namespace`: `(unset)` - Namespace for all topics and transforms.

  The `driver` contains the following keys:

  * name: `oak` - ROS 2 node name; also the prefix in published topic paths (`/<ns>/<name>/rgb/...`).
  * camera-model: `OAK-D-PRO` - one of `OAK-D`, `OAK-D-LITE`, `OAK-1`, `OAK-1-LITE`, `OAK-D-PRO`, `OAK-D-PRO-W`. Used for snap-side validation; the depthai driver autodetects the actual hardware.
  * camera-params: `default` - Sets the camera parameters based on `/var/snap/husarion-depthai/current/camera-params-<VALUE>.yaml`. Bundled presets: `default`, `oak-1-lite`, `oak-d-pro`, `oak-d-pro-poe`, `oak-d-pro-slam`. Bundled presets are refreshed on every `snap refresh`; user-added presets in this directory are preserved.
  * ffmpeg-params: `default` - Sets the FFMPEG parameters based on `/var/snap/husarion-depthai/current/ffmpeg-params-<VALUE>.yaml`
  * startup-delay: `30` - Seconds to sleep on first launch after a fresh boot (uptime < startup-delay+60s). Set to `0` or `''` to disable. Workaround for depthai-ros USB cold-start race; tune higher (60+) for slow-booting hosts, lower (10-15) for fast x86.
  * enable-pointcloud: `false` - Load `depth_image_proc::PointCloudXyzrgbNode` and force RGB/stereo timestamp sync. Requires RGBD pipeline (e.g. `camera-params=oak-d-pro`).
  * rectify-rgb: `true` - Load `image_proc::RectifyNode` to publish `<name>/rgb/image_rect` alongside the raw stream. Set `false` to skip rectification (saves a bit of CPU; `image_raw` is always published either way).

  To set the parameters, use the snap set command, e.g.,

     snap set husarion-depthai driver.namespace=robot

  **Husarion cockpit integration**

  This snap embeds **husarion-agent** as a chain follower (leaf). In a Husarion cockpit setup the ROS network config — RMW (including Zenoh), `ROS_DOMAIN_ID`, and namespace — is set once from the WebUI **Manage** tab on the chain owner and propagated here automatically. The `ros.*` keys above are the standalone / direct-`snap set` path (Zenoh is driven through the agent, not `ros.transport`).

grade: stable
confinement: strict
base: {{ 'core22' if ros_distro == 'humble' else 'core24' }}
# Content interface + same-publisher auto-connect for zero-config snap chaining
# (SPEC-content-chain).
assumes: [snapd2.43]

# Chained-agents leaf follower of the rosbot snap's cascading primary on :7444.
# No HA_PEER_BIND (no downstream subscribers).
environment:
  HA_TIER: "robot"

contact: https://github.com/husarion/depthai-snap/issues
issues: https://github.com/husarion/depthai-snap/issues
website: https://husarion.com/

slots:
  shm-slot:
    interface: shared-memory
    write: ['*'] # paths are relative to /dev/shm

plugs:
  shm-plug:
    interface: shared-memory
    shared-memory: shm-slot
    private: false
  # Zero-config snap chaining (SPEC-content-chain): when installed alongside the
  # rosbot snap (same publisher), snapd auto-connects this plug to rosbot's
  # agent-chain slot; connect-plug-agent-chain then self-joins via the CSR
  # drop-box. `default-provider` is an install hint; the matcher is
  # publisher-id + the content tag.
  agent-chain:
    interface: content
    content: husarion-agent-chain
    target: $SNAP_COMMON/agent-chain-upstream
    default-provider: rosbot

apps:

  daemon:
    command: usr/bin/launcher.sh
    command-chain: [usr/bin/ros_setup.sh]
    daemon: simple
    install-mode: enable
    restart-condition: always
    plugs: [network, network-bind, shm-plug, raw-usb, hardware-observe]
    slots: [shm-slot]
    extensions: [ros2-{{ ros_distro }}-ros-base]

  husarion-depthai:
    command: usr/bin/launcher.sh
    command-chain: [usr/bin/check_daemon_running.sh, usr/bin/ros_setup.sh]
    plugs: [network, network-bind, shm-plug, raw-usb, hardware-observe]
    slots: [shm-slot]
    extensions: [ros2-{{ ros_distro }}-ros-base]

  start:
    command: usr/bin/start_launcher.sh

  restart:
    command: usr/bin/restart_launcher.sh

  stop:
    command: usr/bin/stop_launcher.sh

  # Chained-agents leaf follower. Subscribes to the rosbot snap's cascading
  # primary on :7444 (which follows the cockpit BIC on :7443). A network change
  # cascades cockpit BIC → rosbot → husarion-depthai (no listener); the seeded
  # hooks/network calls `snapctl set ros.<key>` against this snap's own config.
  husarion-agent:
    command: usr/bin/husarion_agent_launcher.sh
    daemon: simple
    install-mode: enable
    restart-condition: always
    plugs: [network, network-bind]

  peer-join:
    command: usr/bin/husarion-agent
    plugs: [network]

parts:

  # uncomment when depthai-ros package for jazzy is available here: https://index.ros.org/search/?term=depthai
  husarion-depthai:
    plugin: nil
    stage-packages:
      - ros-{{ ros_distro }}-depthai-ros
      - ros-{{ ros_distro }}-image-transport
      - ros-{{ ros_distro }}-image-transport-plugins
      # https://index.ros.org/p/ffmpeg_image_transport/github-ros-misc-utilities-ffmpeg_image_transport/#humble
      - ros-{{ ros_distro }}-ffmpeg-image-transport
      - ffmpeg
      - ros-{{ ros_distro }}-cv-bridge
      - ros-{{ ros_distro }}-rmw-fastrtps-cpp
      - ros-{{ ros_distro }}-rmw-cyclonedds-cpp
      - ros-{{ ros_distro }}-rmw-zenoh-cpp
      # needed to run ffmpeg without errors:
      - libpulse-dev
      - libblas3
      - libjpeg-turbo8-dev
    override-stage: |
      craftctl default
      version="$(apt-cache policy ros-{{ ros_distro }}-depthai-ros-driver | grep Candidate | awk '{print $2}')"
      craftctl set version="$version"
      craftctl set grade="stable"

  local-files:
    plugin: dump
    source: snap/local/
    organize:
      '*.sh': usr/bin/
      '*.py': usr/bin/
      '*.yaml': usr/share/husarion-depthai/config/
      'AGENTS.md': usr/share/husarion-depthai/AGENTS.md
      # '*.xml': usr/share/husarion-depthai/config/
      # '*.json': usr/share/husarion-depthai/config/

  husarion-snap-common:
    plugin: dump
    source: https://github.com/husarion/husarion-snap-common
    # 0.10.0 adds the files-first husarion-agent launcher + the content-chain
    # launcher logic + content-*.sh helpers (SPEC-content-chain). depthai gains
    # the embedded husarion-agent for the first time here.
    source-tag: "0.11.0"
    source-type: git
    build-environment:
      - YQ_VERSION: "v4.35.1"
    build-packages:
      - curl
    organize:
      'local-ros/*.sh': usr/bin/
      'local-ros/rmw/fastdds/*.xml': usr/share/husarion-snap-common/config/rmw/fastdds/
      'local-ros/rmw/cyclonedds/*.xml': usr/share/husarion-snap-common/config/rmw/cyclonedds/
      'local-ros/rmw/zenoh/*.json5': usr/share/husarion-snap-common/config/rmw/zenoh/
      'local-ros/rmw/zenoh-router/*.json5': usr/share/husarion-snap-common/config/rmw/zenoh-router/
      'local-ros/ros.env': usr/share/husarion-snap-common/config/
      # husarion-agent shared substrate (files-first): fetch-binary.sh (build-time,
      # consumed by the husarion-agent part) + the files-first launcher (the agent
      # daemon command). Files-first config (hooks/manifests) ships per-snap via
      # husarion-agent-extras/config-seed/.
      'husarion-agent/fetch-binary.sh':            usr/share/husarion-snap-common/husarion-agent/fetch-binary.sh
      'husarion-agent/launcher.sh':                usr/bin/husarion_agent_launcher.sh
      'husarion-agent/configure-snap-to-files.sh': usr/bin/configure-snap-to-files.sh
      # Content-interface chaining helpers (SPEC-content-chain).
      'husarion-agent/content-*.sh':               usr/bin/
    override-build: |
      craftctl default
      curl -L "https://github.com/mikefarah/yq/releases/download/${YQ_VERSION}/yq_linux_${CRAFT_ARCH_BUILD_FOR}" -o $CRAFT_PART_BUILD/yq
    override-prime: |
      craftctl default
      cp $CRAFT_PART_BUILD/yq $CRAFT_PRIME/usr/bin/yq
      chmod +x $CRAFT_PRIME/usr/bin/yq
      rm -rf $CRAFT_PRIME/local-ros $CRAFT_PRIME/husarion-agent

  # Chained-agents binary + per-snap files-first config seed. The binary fetch +
  # files-first launcher ship from husarion-snap-common; only the config-seed
  # (identity + follow.yaml + the leaf network/rmw hooks + manifests) is
  # per-snap. depthai is a leaf follower (role:leaf, follows the rosbot snap's
  # :7444). SPEC-content-chain Phase 4.
  husarion-agent:
    plugin: dump
    after: [husarion-snap-common]
    source: snap/husarion-agent-extras/
    source-type: local
    build-environment:
      - HA_VERSION: "1.4.0"
    build-packages:
      - curl
    override-build: |
      set -euo pipefail
      craftctl default
      bash "${CRAFT_STAGE}/usr/share/husarion-snap-common/husarion-agent/fetch-binary.sh"
      install -Dm755 "${CRAFT_PART_BUILD}/husarion-agent" "${CRAFT_PART_INSTALL}/usr/bin/husarion-agent"
    organize:
      'config-seed/': usr/share/husarion-agent/config-seed/

  fix-execstack:
    plugin: nil
    after:
      - husarion-depthai
      - local-files
      - husarion-snap-common
      - husarion-agent
    build-packages:
      - execstack
    override-prime: |
      set -eu
      craftctl default

      # Ubuntu Noble universe ships libamdhip64-5 (5.7.1-3, verified 2026-05) with
      # PT_GNU_STACK=RWE — the binary requests an executable stack. Snap strict
      # confinement (apparmor) refuses dlopen on such libs, so the daemon would
      # crash on first use of OpenCV/cv-bridge/ffmpeg paths that pull HIP transitively.
      # `execstack -c` clears the X bit (post-fix flags become RW), letting the
      # library load under strict confinement.
      #
      # Verify before bumping ros-{distro}-depthai-ros:
      #   apt-get download libamdhip64-5 && dpkg -x libamdhip64-5*.deb /tmp/x
      #   readelf -l /tmp/x/usr/lib/x86_64-linux-gnu/libamdhip64.so.5 | grep GNU_STACK
      # If RW upstream → this whole part can be removed. Until then, required.
      #
      # Scope: only libamdhip64.so* needs the fix; no other staged .so has execstack
      # ON in current builds (re-scan with `readelf -l <so> | grep GNU_STACK`).
      # On arm64 the path doesn't exist (HIP isn't packaged for arm64) — loop is a no-op.
      choosen_files=(
        usr/lib/x86_64-linux-gnu/libamdhip64.so*
      )

      for f in "${choosen_files[@]}"; do
        if [ -f "$f" ]; then
          execstack -c "$f"
        fi
      done
