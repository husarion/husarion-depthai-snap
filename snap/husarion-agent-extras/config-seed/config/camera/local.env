# Per-device capability flags for the files-first `camera` concern (local scope,
# never synced). Seeded false so the concern EXISTS + is advertised from the
# first agent boot; the configure hook overwrites these with the model-correct
# values (from driver.camera-model) so Manage shows the depth / IMU / IR cards
# on a camera that actually has those sensors. camera-probe.py (run by the
# concern's apply hook, which has python via the ROS env) refines them further
# and fills the resolution/fps dynamic-enum options.
HAS_STEREO=false
HAS_IR=false
HAS_IMU=false
DETECTED_MODEL=
