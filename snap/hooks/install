#!/bin/bash -e

# Define a function to log and echo messages
source "$SNAP/usr/bin/utils.sh"

"$SNAP/usr/bin/install_hook_ros.sh"

# driver.* defaults — shared with post-refresh so new params introduced in a
# later snap revision are auto-applied (without clobbering user-modified values).
"$SNAP/usr/bin/apply_defaults.sh"

if ! snapctl is-connected raw-usb; then
  log "Plug 'raw-usb' isn't connected, please run:"
  log "sudo ${SNAP_COMMON}/post_install.sh"
fi
log "Set the camera model before starting: sudo snap set ${SNAP_NAME} driver.model=<OAK-1|OAK-1-LITE|OAK-D|OAK-D-LITE|OAK-D-PRO|OAK-D-PRO-W>; pick the pipeline with driver.camera-params=<preset>"

# Bundled YAML presets live in $SNAP_DATA (per-revision) so they're refreshed
# on every snap upgrade — see snap/hooks/post-refresh. User custom presets in
# $SNAP_DATA are preserved by snapd's data migration across refreshes.
cp "${SNAP}/usr/share/${SNAP_NAME}/config/"*.yaml "${SNAP_DATA}/"

# post_install.sh stays in $SNAP_COMMON — it's a user-facing helper, not a runtime preset.
cp "$SNAP/usr/bin/post_install.sh" "${SNAP_COMMON}/"
# On-device operator/AI usage guide (regenerated from the snap each install/refresh).
cp -f "$SNAP/usr/share/husarion-depthai/AGENTS.md" "${SNAP_COMMON}/AGENTS.md"

# # # copy meshes to shared folder
# log "copy meshes to '${SNAP_COMMON}/ros2_ws/'"
# mkdir -p ${SNAP_COMMON}/ros2_ws
# cp -r $SNAP/opt/ros/humble/share/depthai_descriptions ${SNAP_COMMON}/ros2_ws/depthai_descriptions
