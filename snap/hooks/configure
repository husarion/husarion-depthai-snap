#!/bin/bash -e

# The configure hook is called every time one the following actions happen:
# - initial snap installation
# - snap refresh
# - whenever the user runs snap set|unset to change a configuration option

# Define a function to log and echo messages
source "$SNAP/usr/bin/utils.sh"

# Legacy key migration (driver.camera-model -> driver.model). Runs before
# validate_keys, so an old `snap set … driver.camera-model=…` still lands: it
# is folded into driver.model here instead of failing validation.
OLD_CAMERA_MODEL="$(snapctl get driver.camera-model)"
if [ -n "$OLD_CAMERA_MODEL" ]; then
  snapctl set driver.model="$OLD_CAMERA_MODEL"
  snapctl set driver.camera-model!
  log_and_echo "Warning: 'driver.camera-model' is deprecated — value '${OLD_CAMERA_MODEL}' migrated to 'driver.model'. Use 'snap set ${SNAP_NAME} driver.model=…' from now on."
fi

# # Define the top-level key and the list of valid keys
VALID_DRIVER_KEYS=(
  "name"
  "model"
  "camera-params"
  "ffmpeg-params"
  "startup-delay"
  "enable-pointcloud"
  "rectify-rgb"
)

# common

validate_keys "driver" VALID_DRIVER_KEYS[@]

# validate driver.name
validate_regex "driver.name" '^[a-z_-]{1,10}$'

# validate driver.model — unset on fresh installs; the launcher refuses to
# start until the operator picks one (rosbot's driver.model pattern)
VALID_CAMERA_MODEL_OPTIONS=("OAK-D" "OAK-D-LITE" "OAK-1" "OAK-1-LITE" "OAK-D-PRO" "OAK-D-PRO-W")
validate_option --allow-unset "driver.model" VALID_CAMERA_MODEL_OPTIONS[@]

SUPPORTED_RANGE=(0 120)
validate_number --allow-unset "driver.startup-delay" SUPPORTED_RANGE[@]

VALID_BOOL_OPTIONS=("true" "false")
validate_option "driver.enable-pointcloud" VALID_BOOL_OPTIONS[@]
validate_option "driver.rectify-rgb" VALID_BOOL_OPTIONS[@]

# export LD_LIBRARY_PATH=$SNAP/usr/lib/$(uname -m)-linux-gnu/pulseaudio:$SNAP/usr/lib/$(uname -m)-linux-gnu/blas:$SNAP/usr/lib/$(uname -m)-linux-gnu/lapack:$LD_LIBRARY_PATH

# validate driver.camera-params and driver.ffmpeg-params (live in $SNAP_DATA;
# validate_config_param from utils.sh hardcodes $SNAP_COMMON, so we check inline)
for param in camera-params ffmpeg-params; do
    value=$(snapctl get "driver.${param}")
    file="${SNAP_DATA}/${param}-${value}.yaml"
    if [ ! -f "$file" ]; then
        available=$(ls "${SNAP_DATA}/" 2>/dev/null | grep -oE "${param}-.+\.yaml$" | sed -E "s/^${param}-(.*)\.yaml$/\1/" | tr '\n' ' ')
        log_and_echo "'${value}' is not a valid value for 'driver.${param}'. There is no '${file}'. Available options: ${available}"
        exit 1
    fi
done

# Populate the files-first `camera` concern's capability flags so Manage renders
# the right per-capability cards — the depth/imu/ir cards are gated (visible_when)
# on HAS_STEREO/HAS_IMU/HAS_IR. These mirror camera-probe.py's static matrix by
# camera class; the probe (run by the concern's apply hook, which has python via
# the ROS env — snap hooks have none) refines them and fills the resolution/fps
# dynamic-enum options on first apply. Guard on the agent having seeded its
# config-root: the install-time configure runs BEFORE the agent's first start,
# and creating config/ early would make the launcher's IF-ABSENT seed skip
# network/rmw. The deploy's `snap set driver.model` re-fires this with
# config/ present. Writes files only (no snapctl set) so it can't disturb the
# pipeline chosen via driver.camera-params.
if [ -d "${SNAP_COMMON}/husarion-agent/config" ]; then
    cam_model="$(snapctl get driver.model)"; : "${cam_model:=OAK-D-PRO}"
    case "$cam_model" in
        OAK-1|OAK-1-LITE)      has_stereo=false; has_ir=false; has_imu=false ;;
        OAK-D|OAK-D-LITE)      has_stereo=true;  has_ir=false; has_imu=true  ;;
        OAK-D-PRO|OAK-D-PRO-W) has_stereo=true;  has_ir=true;  has_imu=true  ;;
        *)                     has_stereo=true;  has_ir=false; has_imu=true  ;;
    esac
    cam_dir="${SNAP_COMMON}/husarion-agent/config/camera"
    mkdir -p "$cam_dir"
    cam_env="${cam_dir}/local.env"
    # Preserve any other local-scope keys (e.g. MXID/IP); rewrite only ours.
    keep="$(grep -vE '^(HAS_STEREO|HAS_IR|HAS_IMU|DETECTED_MODEL)=' "$cam_env" 2>/dev/null || true)"
    {
        [ -n "$keep" ] && printf '%s\n' "$keep"
        printf 'HAS_STEREO=%s\nHAS_IR=%s\nHAS_IMU=%s\nDETECTED_MODEL=%s\n' \
            "$has_stereo" "$has_ir" "$has_imu" "$cam_model"
    } > "$cam_env"
    # Mirror the probe's per-model res/fps option lists into $SNAP_DATA/caps so
    # the rgb/depth resolution + fps dynamic-enum dropdowns are populated. The
    # python probe refines these (incl. live mxid detection) on the concern's
    # first apply.
    write_caps() { d="${SNAP_DATA}/caps/$1"; rm -rf "$d"; mkdir -p "$d"; shift; for v in "$@"; do : > "${d}/${v}.opt"; done; }
    write_caps model OAK-1 OAK-1-LITE OAK-D OAK-D-LITE OAK-D-PRO OAK-D-PRO-W
    case "$cam_model" in OAK-1-LITE|OAK-D-LITE) rgb_fps_opts=(30) ;; *) rgb_fps_opts=(30 60) ;; esac
    write_caps rgb_resolution 720P 1080P 4K
    write_caps rgb_fps "${rgb_fps_opts[@]}"
    if [ "$has_stereo" = true ]; then
        case "$cam_model" in OAK-D-LITE) depth_res_opts=(400P 480P) ;; *) depth_res_opts=(400P 720P 800P) ;; esac
        write_caps depth_resolution "${depth_res_opts[@]}"
        write_caps depth_fps 30 60
    fi
    log "camera concern caps: model=$cam_model stereo=$has_stereo imu=$has_imu ir=$has_ir"
fi

# depthai_ros driver is a plain rclcpp node — RMW-agnostic, including zenoh.
# The husarion-snap-common zenoh gate exists for snaps that pair zenoh with a
# non-zenoh bridge (e.g. micro_ros_agent); depthai has no such bridge, so opt in.
export HSC_ALLOW_ZENOH=1

"$SNAP/usr/bin/configure_hook_ros.sh"

# restart the daemon with new ROS 2 config
if snapctl services "${SNAP_NAME}.daemon" | grep -qw enabled; then
  snapctl restart "${SNAP_NAME}.daemon"
  log "Restarted ${SNAP_NAME}.daemon"
fi
